{
  "App": {
    "SelfUrl": "https://localhost:5000",
    "ClientUrl": "http://localhost:4201",
    "CorsOrigins": "https://*.afonsoft.dev,http://localhost:4200,http://localhost:4201,http://MeetClientWeb:4200,http://MeetAdminWeb:4201",
    "RedirectAllowedUrls": "http://localhost:4200"
  },
  "ConnectionStrings": {
    "Default": "Host=192.168.68.113;Port=5432;Database=familychat_db;User ID=FamilyChat_user;Password=M5WiBbFeKjfXk4a2;"
  },
  "AuthServer": {
    "Authority": "https://api.afonsoft.dev",
    "RequireHttpsMetadata": false,
    "SwaggerClientId": "FamilyMeet_Swagger"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "nFIHKssInKToTkWw"
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "ForwardedHeaders": "XForwardedFor,XForwardedProto,XForwardedHost",
    "AllowedHosts": "localhost,127.0.0.1,::1",
    "KnownProxies": "127.0.0.1,::1,192.168.68.113",
    "ForwardLimit": null,
    "RequireHeaderSymmetry": false,
    "ForwardedForHeaderName": "X-Forwarded-For",
    "ForwardedProtoHeaderName": "X-Forwarded-Proto",
    "ForwardedHostHeaderName": "X-Forwarded-Host"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Volo.Abp": "Information",
        "Microsoft.AspNetCore.SignalR": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/familymeet-debug-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Debug",
        "Args": {
          "path": "Logs/familymeet-debug-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 3,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithProcessId"
    ],
    "Properties": {
      "Application": "FamilyMeet.HttpApi.Host",
      "Environment": "Development"
    }
  }
}