# Environment Variables for FamilyMeet Docker Compose
# Copy this file to .env and adjust the values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database Host
# For local development: 192.168.68.113
# For Docker containers: host.docker.internal
POSTGRESDB_HOST=192.168.68.113

# PostgreSQL Database Port
POSTGRESDB_PORT=5432

# Database Name
POSTGRESDB_NAME=FamilyChat_db

# Database User
POSTGRESDB_USER=postgres

# Database Password
POSTGRESDB_PASSWORD=postgres

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis Host
# For local development: 192.168.68.113
# For Docker containers: host.docker.internal
REDIS_HOST=192.168.68.113

# Redis Port
REDIS_PORT=6379

# Redis Password (if configured)
REDIS_PASSWORD=

# Redis Instance Name
REDIS_INSTANCE_NAME=FamilyMeet

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT Issuer
JWT_ISSUER=FamilyMeet

# JWT Audience
JWT_AUDIENCE=FamilyMeetUsers

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
JWT_KEY=FamilyMeetSecretKey123456789

# JWT Expiration (in minutes)
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# API CONFIGURATION
# =============================================================================
# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production

# API URL
ASPNETCORE_URLS=http://+:5000

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# ClientWeb Port
CLIENTWEB_PORT=4200

# AdminWeb Port
ADMINWEB_PORT=4201

# =============================================================================
# DOCKER NETWORK CONFIGURATION
# =============================================================================
# Docker Network Name
DOCKER_NETWORK_NAME=familymeet-network

# Docker Network Subnet
DOCKER_NETWORK_SUBNET=172.20.0.0/16

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# .NET Garbage Collection Server
DOTNET_GC_SERVER=true

# .NET Concurrent GC
DOTNET_GC_CONCURRENT=true

# .NET Processor Count
DOTNET_PROCESSOR_COUNT=2

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log File Max Size
LOG_MAX_SIZE=10m

# Log File Max Count
LOG_MAX_FILE=3

# =============================================================================
# RESOURCE LIMITS
# =============================================================================
# API Memory Limit (MB)
API_MEMORY_LIMIT=1024

# API CPU Limit
API_CPU_LIMIT=1

# ClientWeb Memory Limit (MB)
CLIENTWEB_MEMORY_LIMIT=256

# ClientWeb CPU Limit
CLIENTWEB_CPU_LIMIT=0.25

# AdminWeb Memory Limit (MB)
ADMINWEB_MEMORY_LIMIT=512

# AdminWeb CPU Limit
ADMINWEB_CPU_LIMIT=0.5

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
# Health Check Interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Health Check Timeout (seconds)
HEALTH_CHECK_TIMEOUT=10

# Health Check Retries
HEALTH_CHECK_RETRIES=3

# Health Check Start Period (seconds)
HEALTH_CHECK_START_PERIOD=40

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
# Override for development environment
# Uncomment for local development
# POSTGRESDB_HOST=192.168.68.113
# REDIS_HOST=192.168.68.113

# Override for Docker environment
# Uncomment for Docker containers
# POSTGRESDB_HOST=host.docker.internal
# REDIS_HOST=host.docker.internal

# =============================================================================
# SECURITY NOTES
# =============================================================================
# IMPORTANT: 
# 1. Change JWT_KEY in production
# 2. Use strong passwords for database
# 3. Configure firewall rules for external access
# 4. Use SSL/TLS in production
# 5. Regularly update dependencies
